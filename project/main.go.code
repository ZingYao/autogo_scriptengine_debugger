	js_model "github.com/ZingYao/autogo_scriptengine/js_engine/model"
	"github.com/ZingYao/autogo_scriptengine/lua_engine"
	lua_autogo "github.com/ZingYao/autogo_scriptengine/lua_engine/define/autogo/all_models"
	lua_model "github.com/ZingYao/autogo_scriptengine/lua_engine/model"
	lua_lrappsoft "github.com/ZingYao/autogo_scriptengine/lua_engine/define/lrappsoft_models"

	"github.com/dop251/goja"
